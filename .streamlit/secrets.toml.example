# ── Streamlit secrets (EXAMPLE) ──────────────────────────────────────
# Do NOT put real values here and do NOT commit secrets.toml.
#
# On Streamlit Community Cloud: open your app → Settings → Secrets, and
# paste the four lines below WITH your real values. That store is encrypted
# and is never part of the GitHub repo.
#
# Locally you don't need this file at all — the app reads ../temmy-access/secrets.env.

TEMMY_API_BASE_URL = "https://temmy-api-prod-zfxujusd3q-nw.a.run.app"
TEMMY_API_KEY = "your-temmy-standard-key"
TEMMY_QUERY_RUNS_API_KEY = "your-temmy-query-runs-key"
COMPANIES_HOUSE_API_KEY = "your-companies-house-rest-key"
TEMMY_API_TIMEOUT_SECONDS = "30"
